{
  "name": "redis-packhash",
  "version": "0.1.0",
  "description": "Client-agnostic Redis helper that stores key→value pairs in bucketed hashes so they stay in the memory-compact listpack/ziplist encoding. Works with ioredis, node-redis, or any client exposing the hash commands.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json",
    "verify": "npm run typecheck && npm test && npm run build",
    "preversion": "npm run verify",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "redis",
    "listpack",
    "hash",
    "bucketing",
    "memory"
  ],
  "author": "Fariz Prawira <farizprawira94@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FarizPrawira/redis-packhash.git"
  },
  "bugs": {
    "url": "https://github.com/FarizPrawira/redis-packhash/issues"
  },
  "homepage": "https://github.com/FarizPrawira/redis-packhash#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "ioredis": "^5.11.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
